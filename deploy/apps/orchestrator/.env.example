# Per-app secrets and overrides for the Hugo orchestrator.
# Copy to .env on the server; never commit the real file. On
# server-instance-template the ./deploy helper enforces mode 600.
#
# Fill this in BEFORE deploying: a token_env that resolves empty is a hard
# startup error (never a silent anonymous fallback), and ./deploy waits for
# the container to become healthy.

# Secrets referenced from sites.yaml (token_env / secret_env).
# Tokens need read access to the repo: either a fine-grained PAT (Contents:
# read) per repo, or one classic PAT (repo scope) shared across sites —
# several sites may reference the same token_env variable.
# Webhook secrets: one per site, e.g. `openssl rand -hex 32`.
DOCS_GIT_TOKEN=
DOCS_WEBHOOK_SECRET=

# Operational overrides (defaults shown; uncomment to change).
# Durations use Go syntax: 90s, 10m, 1h.
# Changes are picked up on container recreate (docker compose up -d), not restart.
#ORCH_LOG_LEVEL=info
#ORCH_MAX_CONCURRENT_BUILDS=2
#ORCH_BUILD_TIMEOUT=10m
#ORCH_GIT_TIMEOUT=2m
#ORCH_OPERATION_RETRIES=2
#ORCH_RETRY_BACKOFF=1s
#ORCH_BUILD_RETENTION_COUNT=5
#ORCH_SHUTDOWN_GRACE=30s
#ORCH_WEBHOOK_MAX_BODY_BYTES=262144
#ORCH_WEBHOOK_REPLAY_WINDOW=10m
#ORCH_STATIC_ROOT=/srv/static
#ORCH_SITES_CONFIG=/config/sites.yaml
#ORCH_WEBHOOK_LISTEN=0.0.0.0:8080
